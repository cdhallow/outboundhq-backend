PORT=3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio — VoIP calling
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Assembly.ai — call transcription
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# Anthropic Claude — AI call summaries
ANTHROPIC_API_KEY=your-anthropic-api-key

# Public URL of this backend (used to build Twilio webhook callback URLs)
# For local dev: use ngrok → "ngrok http 3000" and paste the https URL here
BACKEND_URL=https://your-railway-app.railway.app
